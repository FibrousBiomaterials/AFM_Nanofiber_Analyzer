# ===== Python bytecode =====
__pycache__/
*.py[cod]
*.pyo

# ===== Test and tool caches =====
.pytest_cache/
.ruff_cache/
.tmp/

# ===== Virtual environments =====
.venv/
venv/
env/
.env/
.conda-env/

# ===== PyInstaller build output =====
build/
dist/
*.spec
# Keep Main.auto.spec only if you intentionally version-control it.
# Remove the *.spec line above if so.

# ===== Distribution / packaging =====
*.egg-info/
.eggs/

# ===== IDE and editor settings =====
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ===== OS-generated files =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Personal AI-tool configuration =====
# CLAUDE.md and AGENTS.md are intentionally version-controlled.
.claude/
.lang_preference

# ===== Internal documentation (not for publication) =====
# Keep the local publication and submission checklist out of the repository.
/TODO.md
# Local maintainer release checklist (Japanese, internal-only).
/RELEASING.md
# Local notes on GitHub repository publication settings (Japanese, internal-only).
/GITHUB_PUBLICATION_SETTINGS.md

# ===== Promotional drafts (not for publication) =====
# Local working folder for note articles and other promotional material.
# Kept out of the public repository; share drafts privately instead.
promo/

# ===== GUI local settings (machine-specific, regenerated at runtime) =====
guis/afmpp_settings.json

# ===== Sample data =====
# Bruker NanoScope sample scans are 33 MB each; only one representative file
# is version-controlled to keep clone size reasonable.
testdata_Bruker_txt/*
!testdata_Bruker_txt/NDTOC250306.000.txt

# ===== Analysis outputs =====
# Exclude large or sensitive analysis results unless they are sample data
# intentionally checked in under examples/.
# Compiled translation catalogs (locale/**/*.mo) are intentionally
# version-controlled so fresh clones get working translations without Babel.
*.json
# Strict-regression golden baseline must be version-controlled so the
# tests/test_strict_regression.py guard runs (not skips) on fresh clones and CI.
!tests/strict_regression_golden.json
*.b2z
*_param.json
*.npy
# cli.py "export" writes one .npz archive per bundle by default.
*.npz
# Leftovers from interrupted atomic writes (lib/pipeline.py, lib/blosc2_io.py).
*.tmp
# Per-file CSV exports from GUI02/GUI03/GUI04 and cli.py measure/heights.
*_fibers.csv
*_profile.csv
*_heights*.csv
/histogram_stats_*.csv
/histogram_log_*.txt
/heights.csv
# cli.py "export --format csv" writes one <stem>_<key>.csv per bundle array.
*_original.csv
*_calibrated.csv
*_binarized.csv
*_skeletonized.csv
*_bp.csv
*_ep.csv
*_kp.csv
*_dp.csv
*_ka.csv
buildold.py
