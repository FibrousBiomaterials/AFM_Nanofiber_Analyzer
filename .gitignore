# ===== Python bytecode =====
__pycache__/
*.py[cod]
*.pyo

# ===== Virtual environments =====
.venv/
venv/
env/
.env/
.conda-env/

# ===== PyInstaller build output =====
build/
dist/
*.spec
# Keep Main.auto.spec only if you intentionally version-control it.
# Remove the *.spec line above if so.

# ===== Distribution / packaging =====
*.egg-info/
.eggs/

# ===== IDE and editor settings =====
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ===== OS-generated files =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Personal AI-tool configuration =====
# CLAUDE.md and AGENTS.md are intentionally version-controlled.
.claude/
.lang_preference

# ===== GUI local settings (machine-specific, regenerated at runtime) =====
guis/afmpp_settings.json

# ===== Generated local launchers =====
# The conda/anaconda setup scripts still recreate these; 92_* bakes a
# machine-local Anaconda path, so they stay untracked. The venv launcher
# (02_run_from_venv.*) is now a tracked static file and is not listed here.
12_run_from_conda_env.bat
12_run_from_conda_env.sh
92_run_from_anaconda.bat
92_run_from_anaconda.sh

# ===== Sample data =====
# Bruker NanoScope sample scans are 33 MB each; only one representative file
# is version-controlled to keep clone size reasonable.
Bruker_testdata/*
!Bruker_testdata/NDTOC250306.000.txt

# ===== Analysis outputs =====
# Exclude large or sensitive analysis results unless they are sample data
# intentionally checked in under examples/.
# Compiled translation catalogs (locale/**/*.mo) are intentionally
# version-controlled so fresh clones get working translations without Babel.
*.json
# Strict-regression golden baseline must be version-controlled so the
# tests/test_strict_regression.py guard runs (not skips) on fresh clones and CI.
!tests/strict_regression_golden.json
*.b2z
*_param.json
*.npy
buildold.py
