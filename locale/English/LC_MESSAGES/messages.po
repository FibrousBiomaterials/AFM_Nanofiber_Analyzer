msgstr "Analysis Settings (applied only on next analysis)"

#: guis/GUI01_Image_Preprocessor.py:1736
msgid "BGCalibrator"
msgstr "BGCalibrator"

#: guis/GUI01_Image_Preprocessor.py:1747
msgid "bg_method"
msgstr "bg_method"

#: guis/GUI01_Image_Preprocessor.py:1749
msgid "背景推定方式（下の説明参照）。選択に応じて使うパラメータのみ有効化されます"
msgstr ""
"Background estimation method (see descriptions below). Only the "
"parameters used by the selected method are enabled."

#: guis/GUI01_Image_Preprocessor.py:1754
msgid ""
"inpaint : 勾配リッジ検出 + Navier-Stokes "
"inpaint。勾配で繊維マスクを作り背景を補間。汎用だがリッジ検出パラメータの調整が必要"
msgstr ""
"inpaint: gradient ridge detection + Navier-Stokes inpainting. Creates a "
"fiber mask from gradients and interpolates the background. General-"
"purpose, but ridge detection parameters must be tuned."

#: guis/GUI01_Image_Preprocessor.py:1755
msgid "tophat : 形態学的opening。tophat_se_size より細い明るい構造を前景として除去。マスク不要・高速・一様性に優れる"
msgstr ""
"tophat: morphological opening. Removes bright structures thinner than "
"tophat_se_size as foreground. No mask required, fast, and good "
"uniformity."

#: guis/GUI01_Image_Preprocessor.py:1756
msgid ""
"spline1d : 行/列ごとの1D B-スプライン補間（オリジナル方式）。ライン間オフセット（縞）ノイズに有効。spline1d_axis "
"で縞の向きを選択"
msgstr ""
"spline1d: 1D B-spline interpolation by row/column (original method). "
"Effective for line-to-line offset (stripe) noise. Select the stripe "
"direction with spline1d_axis."

#: guis/GUI01_Image_Preprocessor.py:1757
msgid "spline2d : 2D B-スプラインフィット。背景を行毎でなく2D問題として一括で解く。大局的に滑らかな背景に向く"
msgstr ""
"spline2d: 2D B-spline fitting. Solves the background as a single 2D "
"problem instead of row by row. Suitable for globally smooth backgrounds."

#: guis/GUI01_Image_Preprocessor.py:1768
msgid "[tophat時のみ] 構造要素直径"
msgstr "[tophat only] Structuring element diameter"

#: guis/GUI01_Image_Preprocessor.py:1769
msgid "最大ファイバー幅の2〜3倍。奇数(偶数は+1)"
msgstr ""
"Set to 2-3 times the maximum fiber width. Use an odd number (even values "
"are incremented by 1)."

#: guis/GUI01_Image_Preprocessor.py:1773
msgid ""
"[spline1d時のみ] "
"除去する縞の向き。'y'=横縞(各走査ラインが上下にずれるノイズ)を除去/各列を縦に補間。'x'=縦縞を除去/各行を横に補間(良好な結果が多い)"
msgstr ""
"[spline1d only] Direction of stripes to remove. 'y' removes horizontal "
"stripes (noise where scan lines shift up/down) and interpolates each "
"column vertically. 'x' removes vertical stripes and interpolates each row"
" horizontally (often gives good results)."

#: guis/GUI01_Image_Preprocessor.py:1775
msgid "[spline1d時のみ] 行/列スプライン order。実用範囲1〜3 (2=旧pandas互換)。点数不足の行は線形に自動フォールバック"
msgstr ""
"[spline1d only] Row/column spline order. Practical range is 1-3 (2 = "
"legacy pandas-compatible). Rows with too few points automatically fall "
"back to linear fitting."

#: guis/GUI01_Image_Preprocessor.py:1778
msgid "[spline2d時のみ] スプライン次数。実用範囲1〜3 (1=双線形、2=旧pandas互換、3=双立方)。[1,5]"
msgstr ""
"[spline2d only] Spline degree. Practical range is 1-3 (1 = bilinear, 2 = "
"legacy pandas-compatible, 3 = bicubic). [1,5]"

#: guis/GUI01_Image_Preprocessor.py:1780
msgid "[spline2d時のみ] フィット用画素サブサンプル係数。大きいほど高速、品質影響は微少。デフォルト4"
msgstr ""
"[spline2d only] Pixel subsampling factor for fitting. Larger values are "
"faster with only minor quality impact. Default is 4."

#: guis/GUI01_Image_Preprocessor.py:1786
msgid "[inpaint, spline1d, spline2d時] 背景範囲（中心±sigma*係数）を決める係数"
msgstr ""
"[inpaint, spline1d, spline2d] Factor that determines the background range"
" (center ± sigma * factor)."

#: guis/GUI01_Image_Preprocessor.py:1787
msgid "[inpaint, spline1d, spline2d時] [1,0,-1]の急変を繊維として除外する距離しきい値"
msgstr ""
"[inpaint, spline1d, spline2d] Distance threshold for excluding sudden "
"changes such as [1,0,-1] as fibers"

#: guis/GUI01_Image_Preprocessor.py:1788
msgid "[inpaint, spline1d, spline2d時] [1,-1]の急変が一定以上離れている場合に構造とみなすしきい値"
msgstr ""
"[inpaint, spline1d, spline2d] Threshold for treating [1,-1] sudden "
"changes as structures when they are separated by at least this distance"

#: guis/GUI01_Image_Preprocessor.py:1790
msgid "[inpaint, tophat, spline1d時] Savitzky-Golayフィルタの窓幅（平滑化範囲）"
msgstr ""
"[inpaint, tophat, spline1d] Savitzky-Golay filter window length "
"(smoothing range)"

#: guis/GUI01_Image_Preprocessor.py:1791
msgid "[inpaint, tophat, spline1d時] Savitzky-Golayフィルタの多項式次数"
msgstr "[inpaint, tophat, spline1d] Savitzky-Golay filter polynomial order"

#: guis/GUI01_Image_Preprocessor.py:1793
msgid "中央値フィルタを最後にかける（点ノイズに強い）"
msgstr "Apply median filter at the end (robust against point noise)"

#: guis/GUI01_Image_Preprocessor.py:1795
msgid "[inpaint, spline1d, spline2d時] 繊維マスクを膨張させる画素数（0でdilationなし）"
msgstr ""
"[inpaint, spline1d, spline2d] Number of pixels to dilate the fiber mask "
"(0 = no dilation)"

#: guis/GUI01_Image_Preprocessor.py:1797
msgid "[inpaint, spline1d, spline2d時] dilation前にマスクから除外する連結成分の最小面積"
msgstr ""
"[inpaint, spline1d, spline2d] Minimum connected-component area to exclude"
" from the mask before dilation"

#: guis/GUI01_Image_Preprocessor.py:1798
msgid "1でフィルタ無効"
msgstr "1 disables the filter"

#: guis/GUI01_Image_Preprocessor.py:1801
msgid "Segmenter"
msgstr "Segmenter"

#: guis/GUI01_Image_Preprocessor.py:1803
