msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2294
msgid ""
"inpaint : 勾配リッジ検出 + Navier-Stokes "
"inpaint。勾配で繊維マスクを作り背景を補間。汎用だがリッジ検出パラメータの調整が必要"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2295
msgid "tophat : 形態学的opening。tophat_se_size より細い明るい構造を前景として除去。マスク不要・高速・一様性に優れる"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2296
msgid ""
"spline1d : 行/列ごとの1D B-スプライン補間（オリジナル方式）。ライン間オフセット（縞）ノイズに有効。spline1d_axis "
"で縞の向きを選択"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2297
msgid "spline2d : 2D B-スプラインフィット。背景を行毎でなく2D問題として一括で解く。大局的に滑らかな背景に向く"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2309
msgid "[tophat時のみ] 構造要素直径"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2310
msgid "最大ファイバー幅の2〜3倍。奇数(偶数は+1)"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2313
msgid ""
"[spline1d時のみ] "
"除去する縞の向き。'y'=横縞(各走査ラインが上下にずれるノイズ)を除去/各列を縦に補間。'x'=縦縞を除去/各行を横に補間(良好な結果が多い)"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2316
msgid "[spline1d時のみ] 行/列スプライン order。実用範囲1〜3 (2=旧pandas互換)。点数不足の行は線形に自動フォールバック"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2319
msgid "[spline2d時のみ] スプライン次数。実用範囲1〜3 (1=双線形、2=旧pandas互換、3=双立方)。[1,5]"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2321
msgid "[spline2d時のみ] フィット用画素サブサンプル係数。大きいほど高速、品質影響は微少。デフォルト4"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2328
msgid "[inpaint, spline1d, spline2d時] 背景範囲（中心±sigma*係数）を決める係数"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2330
msgid "[inpaint, spline1d, spline2d時] [1,0,-1]の急変を繊維として除外する距離しきい値"
msgstr ""

#: guis/GUI01_Image_Preprocessor.py:2332
